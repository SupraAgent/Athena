{
  "name": "@supra/hermes",
  "version": "0.2.0",
  "description": "Persistent memory for Claude Code sessions — local-first, git-backed, zero-config",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "hermes": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "yaml": "^2.7.1"
  },
  "peerDependencies": {
    "@xenova/transformers": "^2.17.0",
    "chromadb": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@xenova/transformers": {
      "optional": true
    },
    "chromadb": {
      "optional": true
    }
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1",
    "@types/node": "^22.15.3"
  }
}
